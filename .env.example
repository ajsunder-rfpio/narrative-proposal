# Copy to .env.local (gitignored) and fill in. NEVER commit real keys.

# --- Anthropic (production LLM adapter) ---
# Used by the edge functions' AnthropicLLM adapter.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Model id recorded in GenerationRecords and sent to the API. Defaults to
# claude-opus-4-8 when unset.
ANTHROPIC_MODEL=claude-opus-4-8
# Prompt-template version recorded in GenerationRecords. Defaults to v1.
PROMPT_TEMPLATE_VERSION=v1

# --- Supabase (edge functions + persistence) ---
# For `supabase functions serve`, these are provided by `supabase start`
# (printed to the console). Copy the local values here for a local run, or the
# project values for a deployed environment.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
# Anon key is only needed by a browser client, not the edge functions.
SUPABASE_ANON_KEY=your-local-anon-key
